import { chromium } from "playwright";
const browser = await chromium.launch();
const page = await browser.newPage({ viewport: { width: 1900, height: 1000 } });
page.on("pageerror", (e) => console.log("PAGE ERR:", e.message));
await page.goto("http://localhost:3000", { waitUntil: "networkidle" });
await page.evaluate(() => localStorage.clear());
await page.reload({ waitUntil: "networkidle" });
await page.waitForTimeout(1500);
await page.screenshot({ path: "30-landing-wide.png" });

// settings panel
await page.locator("button[title='Settings']").click();
await page.waitForTimeout(400);
await page.screenshot({ path: "31-settings.png" });

// funbox sudden death
await page.locator(".settings-panel .control-button", { hasText: "sudden death" }).click();
await page.waitForTimeout(200);
await page.keyboard.press("Escape");
await page.waitForTimeout(300);
// type wrong char -> restart (typed empty)
await page.locator(".sr-typing-input").focus();
await page.keyboard.type("x", { delay: 20 });
await page.waitForTimeout(300);
let val = await page.locator(".sr-typing-input").inputValue();
console.log("sudden death restarts:", val === "" ? "OK" : `FAIL (${val})`);

// zoom buttons
await page.locator("button[title='Settings']").click();
await page.locator(".settings-panel .control-button", { hasText: "none" }).first().click();
await page.keyboard.press("Escape");
const sizeBefore = await page.evaluate(() => getComputedStyle(document.querySelector(".code-layer")).fontSize);
await page.locator("button[title='Bigger code']").click();
await page.waitForTimeout(300);
const sizeAfter = await page.evaluate(() => getComputedStyle(document.querySelector(".code-layer")).fontSize);
console.log("font step:", sizeBefore, "->", sizeAfter, parseFloat(sizeAfter) > parseFloat(sizeBefore) ? "OK" : "FAIL");
await page.screenshot({ path: "32-bigger.png" });
console.log("done");
await browser.close();
EOF
