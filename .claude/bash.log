import { chromium } from "playwright";
const browser = await chromium.launch();
const page = await browser.newPage({ viewport: { width: 1900, height: 1000 } });
page.on("pageerror", (e) => console.log("PAGE ERR:", e.message));
await page.goto("http://localhost:3000", { waitUntil: "networkidle" });
await page.evaluate(() => localStorage.clear());
await page.reload({ waitUntil: "networkidle" });
await page.waitForTimeout(1200);
const code = await page.evaluate(() => document.querySelector(".code-layer")?.textContent ?? "");
// type up to just before first newline -> caret sits ON the "\n" char
const nl = code.indexOf("\n");
await page.locator(".sr-typing-input").focus();
for (const ch of code.slice(0, nl)) await page.keyboard.type(ch, { delay: 5 });
await page.waitForTimeout(300);
const caret = await page.evaluate(() => {
  const c = document.querySelector(".smooth-caret");
  const r = c.getBoundingClientRect();
  return { h: r.height, w: r.width, visible: r.height > 10 };
});
console.log("caret on newline char:", JSON.stringify(caret), caret.visible ? "OK" : "FAIL");
await page.screenshot({ path: "80-caret-newline.png" });
// finish + check download filename timestamped
const code2 = code;
await page.locator(".sr-typing-input").fill(code2);
await page.waitForTimeout(600);
const dl = page.waitForEvent("download", { timeout: 8000 });
await page.locator("button[title='Save result image']").click();
console.log("download name:", (await dl).suggestedFilename());
await browser.close();
EOF
